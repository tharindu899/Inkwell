{
  "appId": "com.inkwell.notes",
  "appName": "Inkwell",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "GoogleAuth": {
      "scopes": [
        "openid",
        "email",
        "profile",
        "https://www.googleapis.com/auth/drive.appdata"
      ],
      "forceCodeForRefreshTokens": true
    }
  }
}
